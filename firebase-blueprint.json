{
  "entities": {
    "Inquiry": {
      "title": "Quotation Inquiry",
      "description": "A request for a quote from a potential customer",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer's full name" },
        "email": { "type": "string", "format": "email", "description": "Customer's email" },
        "phone": { "type": "string", "description": "Customer's phone number" },
        "company": { "type": "string", "description": "Customer's company name (optional)" },
        "items": { 
          "type": "array", 
          "description": "List of products and quantities requested",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        },
        "comments": { "type": "string", "description": "Additional requirements" },
        "designFileUrl": { "type": "string", "description": "URL to the uploaded design drawing" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "responded"] },
        "createdAt": { "type": "number", "description": "Timestamp of submission" }
      },
      "required": ["name", "email", "phone", "items", "status", "createdAt"]
    },
    "Message": {
      "title": "Contact Message",
      "description": "A general inquiry message from the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Sender's name" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "email", "subject", "message", "createdAt"]
    }
  },
  "firestore": {
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Customer quotation requests"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "General contact form submissions"
    }
  }
}
