rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow public uploads to the "designs" folder
    match /designs/{allPaths=**} {
      allow read, write: if true; 
    }
    // Strict rules for everything else (requires authentication)
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
